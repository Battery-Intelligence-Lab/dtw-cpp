{
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "dtwcpp",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000"
  },
  "permissions": {
    "deny": [
      "Bash(format *)",
      "Bash(diskpart *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(dd *)",
      "Bash(shred *)",

      "Bash(reg *)",
      "Bash(regedit *)",
      "Bash(schtasks *)",
      "Bash(sc config *)",
      "Bash(sc create *)",
      "Bash(sc delete *)",
      "Bash(sc stop *)",
      "Bash(sc start *)",
      "Bash(bcdedit *)",
      "Bash(wmic *)",
      "Bash(takeown *)",
      "Bash(icacls *)",
      "Bash(net user *)",
      "Bash(net localgroup *)",
      "Bash(netsh *)",
      "Bash(cipher /w *)",

      "Bash(powershell -enc *)",
      "Bash(powershell -encodedcommand *)",
      "Bash(powershell -e *)",

      "Bash(shutdown *)",
      "Bash(logoff *)",

      "Bash(cmdkey *)",

      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.aws/**)",
      "Write(~/.ssh/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.aws/**)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Bash(unlink *)",

      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .)",
      "Bash(git restore *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(git stash drop *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",

      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh release *)",
      "Bash(gh api *)",

      "Bash(npm install *)",
      "Bash(npm install)",
      "Bash(npm uninstall *)",
      "Bash(npm update *)",
      "Bash(npm ci *)",
      "Bash(npm ci)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(pip3 install *)",
      "Bash(pip3 uninstall *)",
      "Bash(uv pip install *)",
      "Bash(uv pip uninstall *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",

      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(firebase *)",
      "Bash(gcloud *)",
      "Bash(aws *)",
      "Bash(az *)",

      "Bash(curl *)",
      "Bash(wget *)",

      "Bash(chmod *)",
      "Bash(chown *)",

      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(taskkill *)"
    ],
    "allow": [
      "Bash(git merge *)",
      "Read",
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Bash",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ]
  },
  "plansDirectory": "./.claude/reports",
  "enableAllProjectMcpServers": true,
  "disableAllHooks": false,
  "autoUpdatesChannel": "latest",
  "model": "opusplan"
}
