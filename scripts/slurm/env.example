# === SLURM Remote Configuration ===
#
# Copy this file to `.env` at the PROJECT ROOT directory and edit all values.
# .env is listed in .gitignore and will NEVER be committed.
#
# Usage:
#   cp scripts/slurm/env.example .env
#   # Edit .env with your cluster details
#   uv run scripts/slurm/slurm_remote.py test
#

# ---------------------------------------------------------------------------
# Connection (required)
# ---------------------------------------------------------------------------
SLURM_USER=your_username
SLURM_HOST=login-node.your-cluster.edu

# Two-hop SSH gateway (leave empty for direct SSH).
# Some HPC clusters require connecting through a gateway/bastion host first.
SLURM_GATEWAY=

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# SSH key is RECOMMENDED (most secure). Set the path to your private key.
# SLURM_SSH_KEY=~/.ssh/id_ed25519

# Password fallback. The script also checks the SLURM_PASSWORD environment
# variable and falls back to an interactive prompt if neither is set.
SLURM_PASSWORD=

# ---------------------------------------------------------------------------
# Remote paths
# ---------------------------------------------------------------------------
# Where your cluster home and shared data directories are.
# These vary by cluster -- check with your sysadmin or `echo $HOME` / `echo $DATA`.
SLURM_HOME_FOLDER=/home/your_username
SLURM_DATA_FOLDER=/data/your-project/your_username

# Working directory on the cluster for dtw-cpp builds and tests.
SLURM_REMOTE_BASE=/data/your-project/your_username/dtw-cpp

# ---------------------------------------------------------------------------
# Cluster defaults
# ---------------------------------------------------------------------------
SLURM_PARTITION=short
SLURM_CLUSTER=                     # e.g. "htc" or "arc" (leave empty if single cluster)
SLURM_GPU_GRES=gpu:1               # GPU resource request, e.g. gpu:v100:1, gpu:a100:1

# ---------------------------------------------------------------------------
# Notifications (optional)
# ---------------------------------------------------------------------------
SLURM_EMAIL=                        # e.g. first.last@eng.ox.ac.uk

# ===========================================================================
# Oxford ARC Example
# ===========================================================================
# Uncomment and edit these lines if you are using Oxford ARC:
# See: https://arc-user-guide.readthedocs.io/en/latest/arc-systems.html
#
# SLURM_USER=your_sso_username
# SLURM_HOST=htc-login.arc.ox.ac.uk
# SLURM_GATEWAY=
# SLURM_HOME_FOLDER=/home/your_sso_username
# SLURM_DATA_FOLDER=/data/your-arc-project/your_sso_username
# SLURM_REMOTE_BASE=/data/your-arc-project/your_sso_username/dtw-cpp
# SLURM_PARTITION=short
# SLURM_CLUSTER=htc
# SLURM_GPU_GRES=gpu:1
# SLURM_EMAIL=first.last@eng.ox.ac.uk
